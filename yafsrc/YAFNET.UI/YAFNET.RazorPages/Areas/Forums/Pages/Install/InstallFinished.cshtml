@using YAF.Types.Interfaces

@inject ILocalization Localization;

@model YAF.Types.Modals.InstallModal

@{
    Layout = "_LayoutInstall";

    Localization.TransPage = "INSTALL";
}

<form method="post">
    <div class="modal-body">
	    <ol class="wizard-steps mb-4" id="wizard-steps">
            <li class="completed" data-step="0">@Localization.GetText("Welcome")</li>
		    <li class="completed" data-step="1">@Localization.GetText("TestSettings")</li>
		    <li class="completed" data-step="2">@Localization.GetText("Initialize")</li>
		    <li class="completed" data-step="3">@Localization.GetText("CreateBoard")</li>
            <li class="active" data-step="4">@Localization.GetText("Setup") @Localization.GetText("Finished")</li>
	    </ol>
	    
        <h4>
            @Localization.GetText("Setup") @Localization.GetText("Finished")
        </h4>
        <p class="text-body-secondary">
            @Localization.GetText("FinishDesc")
        </p>
        <p>@Localization.GetText("InitFinish")</p>
    </div>
    <div class="modal-footer">
        <button icon="check-circle"
                button-style="Success"
                asp-page-handler="Complete"
                Text="@Localization.GetText("Finish")"></button>
    </div>
</form>